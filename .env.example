# Client (Vite) vars — baked into the app bundle at build time. Never put secrets here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=files
SUPABASE_FUNCTIONS_URL=

# suggest-filename Edge Function config — these are set as Supabase FUNCTION SECRETS
# (`supabase secrets set NAME=value`), NOT read from this client .env file:
#   ANTHROPIC_API_KEY   (required, secret — sk-ant-...)   never commit or bundle this
#   ANTHROPIC_MODEL     (optional, defaults to claude-haiku-4-5)
